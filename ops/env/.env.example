APP_NAME="Forge Council"
APP_ID="io.aiaast.forge.council"
APP_ENV=prod
APP_BIND_ADDRESS=127.0.0.1
APP_PORT=
APP_PORT_RANGE_START=46300
APP_PORT_RANGE_END=46400
APP_EXEC_START="python3 -m http.server ${APP_PORT:-46300} --bind ${APP_BIND_ADDRESS:-127.0.0.1}"
APP_HEALTHCHECK_URL=http://${APP_BIND_ADDRESS:-127.0.0.1}:${APP_PORT:-46300}/health
DATABASE_MODE=postgres
POSTGRES_HOST_BIND=127.0.0.1
PUBLISH_POSTGRES_PORT=false
POSTGRES_HOST=${POSTGRES_HOST_BIND}
POSTGRES_PORT=5432
POSTGRES_DB=forge-council
POSTGRES_USER=forge-council
POSTGRES_PASSWORD=
REDIS_HOST_BIND=127.0.0.1
PUBLISH_REDIS_PORT=false
REDIS_HOST=${REDIS_HOST_BIND}
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0
SQLITE_PATH=${HOME}/.local/share/forge-council/app.sqlite3
LLM_CONFIG_PATH=ai/llm_config.yaml
# Control plane API (FastAPI)
FC_API_HOST=127.0.0.1
FC_API_PORT=8010
FC_STATE_DB=
FC_API_TOKEN=
OTEL_EXPORTER_OTLP_ENDPOINT=
FC_CORS_ORIGINS=
# Local subprocess dispatch (off unless explicitly enabled)
FC_DISPATCH_KILL_SWITCH=
FC_ALLOW_SUBPROCESS_DISPATCH=
FC_EXEC_ALLOWLIST=
FC_EXEC_WORKDIR=
FC_EXEC_TIMEOUT_SEC=
FC_EXEC_INHERIT_ENV=
SYSTEM_PACKAGES="python3 python3-venv curl"
