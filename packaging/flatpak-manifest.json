{
  "app-id": "io.aiaast.forge.council",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "24.08",
  "sdk": "org.freedesktop.Sdk",
  "command": "forge-council",
  "finish-args": [
    "--share=network",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--device=dri",
    "--filesystem=xdg-config/forge-council:create",
    "--filesystem=xdg-data/forge-council:create"
  ],
  "modules": [
    {
      "name": "forge-council",
      "buildsystem": "simple",
      "build-commands": [
        "install -Dm755 ./dist/forge-council /app/bin/forge-council",
        "install -Dm644 ./packaging/io.aiaast.forge.council.desktop /app/share/applications/io.aiaast.forge.council.desktop"
      ],
      "sources": [
        {
          "type": "dir",
          "path": ".."
        }
      ]
    }
  ]
}
